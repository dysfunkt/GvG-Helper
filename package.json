{
    "name": "gvg-helper",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run deploy && bun src/index.ts",
        "dev:watch": "bun run deploy && bun --watch src/index.ts",
        "deploy": "bun run src/deploy-commands.ts",
        "build": "tsc",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@types/bun": "latest",
        "@types/node": "^26.1.0"
    },
    "peerDependencies": {
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "discord.js": "^14.26.4",
        "dotenv": "^17.4.2",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^4.4.3"
    }
}
